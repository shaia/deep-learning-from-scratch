# ── Node / Astro (see site/.gitignore for site-local rules too) ──
node_modules/
dist/
.astro/

# ── Python ──
__pycache__/
*.py[cod]
.venv/
venv/
.mypy_cache/
.pytest_cache/
.ipynb_checkpoints/

# ── C / build ──
build/
*.o
*.obj
*.exe
*.out

# ── Manim render cache (keep only the final mp4s copied into site/public/media) ──
topics/**/anim/media/
animations/media/

# ── Datasets (downloaded on demand by scripts in data/) ──
data/**/*.gz
data/**/*.idx*
data/**/*.bin
data/**/cifar*/

# ── OS / editor ──
.DS_Store
Thumbs.db

# ── Claude Code (local assistant config, kept out of the repo) ──
.claude/