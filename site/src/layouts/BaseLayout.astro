---
// The book's HTML shell: typography, theme system, KaTeX + code-highlight styling.
// Every page renders through this. Widgets read the current theme from the
// `data-theme` attribute this layout stamps on <html> (see docs/conventions/viz-style.md).
import 'katex/dist/katex.min.css';

interface Props {
  title: string;
  description?: string;
  /** Canonical URL for this page; defaults to the current page on `site`. */
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const siteName = 'Deep Learning From Scratch';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title === siteName ? title : `${title} · ${siteName}`}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalURL} />

    {/* Resolve theme before first paint to avoid a flash. Explicit choice wins;
        otherwise follow the OS preference. Always stamp an explicit data-theme
        so widgets have a definite value to read. */}
    <script is:inline>
      (() => {
        const stored = localStorage.getItem('theme');
        const theme =
          stored === 'light' || stored === 'dark'
            ? stored
            : matchMedia('(prefers-color-scheme: dark)').matches
              ? 'dark'
              : 'light';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">{siteName}</a>
      <button
        id="theme-toggle"
        class="theme-toggle"
        type="button"
        aria-label="Toggle light and dark theme"
      >
        <span class="theme-toggle__icon" aria-hidden="true"></span>
      </button>
    </header>

    <main class="content">
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        Built from scratch · <a href="/">contents</a> · source on
        <a href="https://github.com">GitHub</a>
      </p>
    </footer>

    {/* Theme toggle: flips data-theme and persists the explicit choice.
        Dispatches `themechange` so live widgets can repaint without a reload. */}
    <script is:inline>
      (() => {
        const btn = document.getElementById('theme-toggle');
        if (!btn) return;
        btn.addEventListener('click', () => {
          const next =
            document.documentElement.getAttribute('data-theme') === 'dark'
              ? 'light'
              : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          localStorage.setItem('theme', next);
          window.dispatchEvent(
            new CustomEvent('themechange', { detail: { theme: next } })
          );
        });
      })();
    </script>

    <style is:global>
      /* ── Semantic color roles (docs/conventions/viz-style.md) ─────────────
         Widgets should read these via getComputedStyle rather than hardcoding
         hex, so a single theme change re-colors prose and canvases together.
         Categorical data pair is the colorblind-safe Okabe–Ito blue/orange. */
      :root {
        --color-bg: #fdfdfc;
        --color-surface: #f4f4f2;
        --color-text: #1a1a19;
        --color-muted: #6b6b68;
        --color-border: #e1e1dd;
        --color-link: #2551c9;

        --viz-axis: #9a9a96;         /* neutral / axes / gridlines */
        --viz-data-a: #0072b2;       /* class A  (colorblind-safe) */
        --viz-data-b: #e69f00;       /* class B  (colorblind-safe) */
        --viz-accent: #6d4aff;       /* model / prediction (accent) */
        --viz-action: #d81b60;       /* gradient / update (motion only) */
        --viz-pos: #1b7f5c;          /* positive (diverging) */
        --viz-neg: #c2410c;          /* negative (diverging) */

        --measure: 44rem;            /* readable column width */
        --radius: 8px;
      }

      :root[data-theme='dark'] {
        --color-bg: #16161a;
        --color-surface: #1f1f26;
        --color-text: #e8e8e6;
        --color-muted: #a0a0a0;
        --color-border: #33333b;
        --color-link: #8ab0ff;

        --viz-axis: #6c6c74;
        --viz-data-a: #56b4e9;
        --viz-data-b: #f0b64a;
        --viz-accent: #9d86ff;
        --viz-action: #ff5c93;
        --viz-pos: #3fbf8f;
        --viz-neg: #ff8a5c;
      }

      * { box-sizing: border-box; }

      html {
        font-family: ui-serif, Georgia, 'Times New Roman', serif;
        line-height: 1.7;
        color-scheme: light dark;
      }

      body {
        margin: 0;
        background: var(--color-bg);
        color: var(--color-text);
        transition: background 0.2s ease, color 0.2s ease;
      }

      .site-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: var(--measure);
        margin: 0 auto;
        padding: 1.25rem 1.25rem 0;
      }

      .brand {
        font-weight: 600;
        font-size: 0.95rem;
        letter-spacing: 0.01em;
        text-decoration: none;
        color: var(--color-text);
      }

      .theme-toggle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        border: 1px solid var(--color-border);
        border-radius: 50%;
        background: var(--color-surface);
        cursor: pointer;
        color: var(--color-text);
      }
      .theme-toggle__icon {
        width: 0.85rem;
        height: 0.85rem;
        border-radius: 50%;
        background: var(--viz-accent);
        box-shadow: inset -3px -3px 0 0 var(--color-surface);
      }
      :root[data-theme='dark'] .theme-toggle__icon {
        box-shadow: none;
      }

      .content {
        max-width: var(--measure);
        margin: 0 auto;
        padding: 2rem 1.25rem 4rem;
      }

      .content :is(h1, h2, h3) {
        font-family: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', sans-serif;
        line-height: 1.25;
        letter-spacing: -0.01em;
      }
      .content h1 { font-size: 2.1rem; margin: 0 0 0.5rem; }
      .content h2 { font-size: 1.5rem; margin: 2.5rem 0 0.75rem; }
      .content h3 { font-size: 1.15rem; margin: 2rem 0 0.5rem; }

      .content a { color: var(--color-link); }

      /* Code blocks (Shiki dual-theme). Astro emits light inline; these vars
         swap to the dark palette when the reader picks the dark theme. */
      .astro-code {
        padding: 1rem 1.15rem;
        border-radius: var(--radius);
        border: 1px solid var(--color-border);
        font-size: 0.9rem;
        line-height: 1.55;
        overflow-x: auto;
      }
      :root[data-theme='dark'] .astro-code,
      :root[data-theme='dark'] .astro-code span {
        color: var(--shiki-dark) !important;
        background-color: var(--shiki-dark-bg) !important;
        font-style: var(--shiki-dark-font-style) !important;
        font-weight: var(--shiki-dark-font-weight) !important;
        text-decoration: var(--shiki-dark-text-decoration) !important;
      }

      /* Inline code */
      .content :not(pre) > code {
        font-size: 0.88em;
        padding: 0.12em 0.35em;
        border-radius: 4px;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
      }

      .site-footer {
        max-width: var(--measure);
        margin: 0 auto;
        padding: 2rem 1.25rem 3rem;
        color: var(--color-muted);
        font-size: 0.85rem;
        border-top: 1px solid var(--color-border);
      }
      .site-footer a { color: var(--color-muted); }

      @media (prefers-reduced-motion: reduce) {
        * {
          animation-duration: 0.001ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.001ms !important;
        }
      }
    </style>
  </body>
</html>
